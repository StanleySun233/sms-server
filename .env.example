# Database Configuration
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=sms_server
MYSQL_USER=sms_user
MYSQL_PASSWORD=your_secure_password_here
MYSQL_PORT=3306

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=8080
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_recommended

# Frontend Configuration
FRONTEND_PORT=2888
# API URL for browser requests (use relative path for proxy)
NEXT_PUBLIC_API_URL=/api
# Backend URL for Next.js server-side proxy
BACKEND_URL=http://sms-backend:8080

# Production Domain (for deployment)
DOMAIN=sms.sjsun.top

# Environment (development/production)
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# Docker Image Configuration (for production deployment)
GITHUB_REPOSITORY=stanleysun233
BACKEND_TAG=latest
FRONTEND_TAG=latest
