# Database Configuration (remote: set MYSQL_HOST to your server IP)
MYSQL_HOST=your-server-ip
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=sms_server
MYSQL_USER=smsadmin
MYSQL_PASSWORD=your_secure_password_here
MYSQL_PORT=3306

# Redis Configuration (remote: set REDIS_HOST to your server IP)
REDIS_HOST=your-server-ip
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=8080
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_recommended

# Frontend Configuration
FRONTEND_PORT=2888
# API URL for browser requests (use relative path for proxy)
NEXT_PUBLIC_API_URL=/api
# Backend URL for Next.js server-side proxy (default: no Docker bridge)
BACKEND_URL=http://your-backend-host

# Production Domain (for deployment)
DOMAIN=your-domain.com

# Environment (development/production)
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# Docker Image Configuration (for production deployment, e.g. your-github-username)
GITHUB_REPOSITORY=your-github-username
BACKEND_TAG=latest
FRONTEND_TAG=latest
